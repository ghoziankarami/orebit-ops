# RAG API Wrapper Configuration
# The wrapper first reads local env, then falls back to ../../.env when available.

# API Key for local/public wrapper auth
RAG_API_KEY=your-secret-api-key-here

# Server Port (default: 3004)
PORT=3004

# Optional explicit host
RAG_API_HOST=127.0.0.1

# LLM-backed answer path via OpenRouter
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_MODEL=openai/gpt-oss-120b:free

# Optional response tuning
RAG_STATS_TTL_MS=60000
RAG_RESPONSE_CACHE_TTL_MS=300000

# Optional canonical path overrides for the data provider
OREBIT_WORKSPACE_ROOT=/app/working/workspaces/default
OREBIT_VAULT_ROOT=/app/working/workspaces/default/obsidian-system/vault
OREBIT_CHROMA_ROOT=/app/working/workspaces/default/file_store/chroma
OREBIT_OBSIDIAN_PAPERS_DIR=/app/working/workspaces/default/obsidian-system/vault/3. Resources/Papers
OREBIT_PAPERS_COLLECTION=paper_docs
OREBIT_PAPERS_COLLECTION_FALLBACKS=paper_docs,papers,research_papers
OREBIT_SUMMARIES_COLLECTION=papers_summary
OREBIT_SUMMARIES_COLLECTION_FALLBACKS=papers_summary
