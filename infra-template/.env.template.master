# Master sanitized environment template
# Copy this file to the runtime name you need and fill in the placeholders.
# Secret values have been removed from every entry below.

# ============================================================================
# Core runtime
# ============================================================================
TERMINAL_MODAL_IMAGE=nikolaik/python-nodejs:python3.11-nodejs20
TERMINAL_TIMEOUT=60
TERMINAL_LIFETIME_SECONDS=300
BROWSERBASE_PROXIES=true
BROWSERBASE_ADVANCED_STEALTH=false
BROWSER_SESSION_TIMEOUT=300
BROWSER_INACTIVITY_TIMEOUT=120
WEB_TOOLS_DEBUG=false
VISION_TOOLS_DEBUG=false
MOA_TOOLS_DEBUG=false
IMAGE_TOOLS_DEBUG=false
MESSAGING_CWD=/root/.openclaw/hermes-siro
OBSIDIAN_VAULT_PATH=/data/obsidian

# ============================================================================
# Messaging and bot tokens
# ============================================================================
TELEGRAM_ALLOWED_USERS=your_allowed_telegram_user_ids_here
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
OPENCLAW_CHANNELS_TELEGRAM_ACCOUNTS_DEFAULT_BOTTOKEN=your_default_telegram_bot_token_here
OPENCLAW_CHANNELS_TELEGRAM_ACCOUNTS_SECONDBRAIN_BOTTOKEN=your_second_brain_telegram_bot_token_here
OPENCLAW_CHANNELS_TELEGRAM_ACCOUNTS_TUTOR_BOTTOKEN=your_tutor_telegram_bot_token_here
OPENCLAW_CHANNELS_TELEGRAM_BOTTOKEN=your_openclaw_telegram_bot_token_here
OPENCLAW_GATEWAY_AUTH_TOKEN=your_openclaw_gateway_auth_token_here

# ============================================================================
# Provider and integration keys
# ============================================================================
OPENAI_API_KEY=your_openai_api_key_here
GOOGLE_API_KEY=your_google_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
BRAVE_API_KEY=your_brave_api_key_here
ZAI_API_KEY=your_zai_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here
SCOPUS_API_KEY=your_scopus_api_key_here
ZOTERO_API_KEY=your_zotero_api_key_here
VERCEL_TOKEN=your_vercel_token_here
RAG_API_BASE=https://api.orebit.id/api/rag
RAG_API_KEY=your_rag_api_key_here
MATON_API_KEY=your_maton_api_key_here
LINKEDIN_PERSON_ID=your_linkedin_person_id_here
OPENCLAW_API_KEY=your_openclaw_api_key_here
MAIA_ROUTER_API_KEY=your_maiarouter_api_key_here
MAIAROUTER_API_KEY=your_maiarouter_api_key_here
CUSTOM_API_MAIAROUTER_KEY=your_maiarouter_api_key_here
CUSTOM_API_SUMOPOD_KEY=your_sumopod_api_key_here
CUSTOM_API_SEMUTSSH_KEY=your_semutssh_api_key_here
OPENCLAW_MODELS_PROVIDERS_CUSTOM_AI_SEMUTSSH_COM_APIKEY=your_semutssh_api_key_here
OPENCLAW_MODELS_PROVIDERS_CUSTOM_AI_SUMOPOD_COM_APIKEY=your_sumopod_api_key_here
OPENCLAW_MODELS_PROVIDERS_CUSTOM_API_MAIAROUTER_AI_APIKEY=your_maiarouter_api_key_here

# ============================================================================
# Mission Control backend
# ============================================================================
ENVIRONMENT=dev
LOG_LEVEL=INFO
LOG_FORMAT=text
LOG_USE_UTC=false
REQUEST_LOG_SLOW_MS=1000
REQUEST_LOG_INCLUDE_HEALTH=false
DATABASE_URL=postgresql+psycopg://your_db_user:your_db_password@localhost:5432/mission_control
SECURITY_HEADER_X_CONTENT_TYPE_OPTIONS=
SECURITY_HEADER_X_FRAME_OPTIONS=
SECURITY_HEADER_REFERRER_POLICY=
SECURITY_HEADER_PERMISSIONS_POLICY=
AUTH_MODE=local
LOCAL_AUTH_TOKEN=your_local_auth_token_here
CLERK_SECRET_KEY=your_clerk_secret_key_here
CLERK_API_URL=https://api.clerk.com
CLERK_VERIFY_IAT=true
CLERK_LEEWAY=10.0
BASE_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000
NEXT_PUBLIC_API_URL=/api
POSTGRES_DB=mission_control
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password_here
POSTGRES_PORT=5432
REDIS_PORT=6379
BACKEND_PORT=8000
FRONTEND_PORT=3000
DB_AUTO_MIGRATE=true
RQ_REDIS_URL=redis://localhost:6379/0
RQ_QUEUE_NAME=default
RQ_DISPATCH_THROTTLE_SECONDS=15.0
RQ_DISPATCH_MAX_RETRIES=3
GATEWAY_MIN_VERSION=2026.02.9

# ============================================================================
# OpenClaw template compatibility
# ============================================================================
OPENCLAW_OPENAI_API_KEY=your_openai_api_key_here
OPENCLAW_OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENCLAW_TELEGRAM_BOT_TOKEN=your_openclaw_telegram_bot_token_here
OPENCLAW_TELEGRAM_CHAT_ID=your_telegram_chat_id_here
OPENCLAW_KIRO_AUTH_TOKEN=your_kiro_auth_token_here
