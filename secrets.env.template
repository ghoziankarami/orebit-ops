# Copy this file to: ~/.orebit/secrets.env
# Keep this file out of Git.
# Legacy fallback during migration: ~/.openclaw/secrets.env

# Public RAG UI -> API wrapper base URL
RAG_API_BASE=https://api.orebit.id/api/rag

# Public/API authentication key used by the Vercel proxy and wrapper
RAG_API_KEY=replace-me

# Vercel deploy token for rag-public production deploys
VERCEL_TOKEN=replace-me

# Optional: if the public answer provider still needs OpenRouter in your runtime
OPENROUTER_API_KEY=replace-me

# Optional: if the runtime has moved to ZAI/provider-native settings
ZAI_API_KEY=replace-me
ZAI_URL=https://open.bigmodel.cn/api/paas/v4/chat/completions
ZAI_MODEL=glm-4.7-flash
