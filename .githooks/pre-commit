#!/bin/sh
set -eu

branch=$(git branch --show-current 2>/dev/null || echo "")
user_name=$(git config --get user.name || true)
user_email=$(git config --get user.email || true)
worktree_count=$(git worktree list --porcelain 2>/dev/null | grep -c '^worktree ' || true)

if [ -z "$user_name" ] || [ -z "$user_email" ]; then
  echo "ERROR: git user.name/user.email are not set for this repo." >&2
  echo "Set them before committing." >&2
  exit 1
fi

if [ "$branch" != "main" ] && [ "${ALLOW_NON_MAIN_COMMIT:-}" != "1" ]; then
  echo "ERROR: current branch is '$branch', not 'main'." >&2
  echo "This repo uses a main-first workflow." >&2
  echo "If this branch commit is intentional, rerun with ALLOW_NON_MAIN_COMMIT=1" >&2
  exit 1
fi

if [ "$worktree_count" -gt 1 ] && [ "${ALLOW_MULTI_WORKTREE_COMMIT:-}" != "1" ]; then
  echo "ERROR: multiple git worktrees are active for this repo ($worktree_count detected)." >&2
  echo "Clean them up before committing, or rerun with ALLOW_MULTI_WORKTREE_COMMIT=1 if intentional." >&2
  exit 1
fi

"$(git rev-parse --show-toplevel)/ops/scripts/git/check-runtime-guardrails.sh"

exit 0
